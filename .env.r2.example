# =============================================================
# Cloudflare R2 — Credentials (NE PAS COMMIT)
# =============================================================
# Copiez ce fichier en .env.r2 et remplissez les valeurs.
#
# À obtenir depuis le dashboard Cloudflare > R2 > Manage API Tokens :
#   https://dash.cloudflare.com/ > R2 > Manage R2 API Tokens
#
# Le token doit avoir les permissions "Object Read & Write"
# sur le bucket cible.

R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=odeysseyr2
R2_PUBLIC_URL=https://pub-3358cacf01e046b2a19c24906dbc668a.r2.dev
